# Google Sheets / Service Account
# Path to the service account JSON key file downloaded from Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# The ID of the target Google Spreadsheet (from the URL: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Google Chat
# Incoming Webhook URL for the target Google Chat space
# Create one via: Google Chat space → Apps & integrations → Incoming Webhooks
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/YOUR_SPACE/messages?key=YOUR_KEY&token=YOUR_TOKEN

# Environment tag written into each row (dev | staging | prod)
ENV=dev

# API server authentication token
# Used by the FastAPI server to validate n8n HTTP Request calls (X-Automation-Token header)
# Generate with: openssl rand -hex 32
AUTOMATION_API_TOKEN=your_random_token_here

# Optional: Chromium user-data-dir with an authenticated AirDNA session
# Required only for supply collection (deferred from MVP)
# AIRDNA_USER_DATA_DIR=/path/to/chromium-user-data

# Optional: proxy settings if behind a corporate firewall
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
